{
  "manifest_version": 3,
  "name": "URL Shortener",
  "version": "1.1.0",
  "description": "Shorten URLs with chom.pm and copy to clipboard",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chom.pm/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "shorten-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Shorten the current page URL"
    }
  }
}
